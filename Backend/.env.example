# DubFlow Environment Configuration
# Copy this file to `.env` and fill in your API keys

# ==========================================
# Translation API Configuration (OpenAI-compatible)
# ==========================================

# Option 1: Agnes AI (Recommended - Free/Low cost)
# Get your API key from: https://agnes-ai.com
AGNES_API_KEY=your_agnes_api_key_here
AGNES_BASE_URL=https://apihub.agnes-ai.com/v1
AGNES_MODEL=agnes-2.0-flash

# Option 2: DeepSeek (Alternative - Low cost)
# Get your API key from: https://platform.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Option 3: OpenAI (Original - Higher cost)
# Get your API key from: https://platform.openai.com
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-3.5-turbo

# ==========================================
# Speech-to-Text (Whisper API)
# ==========================================

# Whisper API for speech recognition (used when video has no subtitles)
# Can use the same Agnes AI/DeepSeek/OpenAI endpoint (they support Whisper)
WHISPER_API_KEY=your_whisper_api_key_here
WHISPER_BASE_URL=https://api.openai.com/v1  # or use Agnes/DeepSeek URL
WHISPER_MODEL=whisper-1

# ==========================================
# Text-to-Speech (Edge TTS - Free!)
# ==========================================

# Edge TTS is FREE and requires NO API key!
# It uses Microsoft Edge's online TTS service
# Supported voices: see tts-engine.js for full list
# Examples:
# - Chinese (Simplified): zh-CN-XiaoxiaoNeural (晓晓), zh-CN-YunxiNeural (云希)
# - English (US): en-US-JennyNeural
# - Japanese: ja-JP-NanamiNeural
# - Korean: ko-KR-SunHiNeural
EDGE_TTS_VOICE=zh-CN-XiaoxiaoNeural

# ==========================================
# RapidAPI (Optional - Fallback)
# ==========================================

# RapidAPI Google Translator (Optional - used as fallback)
# Get your API key from: https://rapidapi.com
RAPIDAPI_KEY=your_rapidapi_key_here
RAPIDAPI_HOST=google-translator9.p.rapidapi.com

# ==========================================
# Proxy Configuration (Required for YouTube)
# ==========================================

# Proxy URL for accessing YouTube (required in China)
# Example: http://127.0.0.1:10808
PROXY_URL=http://127.0.0.1:10808

# ==========================================
# Server Configuration
# ==========================================

# Backend server port
PORT=3002

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# ==========================================
# Debug Configuration
# ==========================================

# Enable debug mode (true/false)
DEBUG=true

# ==========================================
# Usage Examples:
# ==========================================

# 1. Using Agnes AI (Recommended):
#    - Set AGNES_API_KEY
#    - Leave DEEPSEEK_API_KEY and OPENAI_API_KEY empty
#    - Translation will use Agnes AI (OpenAI-compatible)

# 2. Using DeepSeek (Low cost):
#    - Set DEEPSEEK_API_KEY
#    - Leave AGNES_API_KEY and OPENAI_API_KEY empty
#    - Translation will use DeepSeek (OpenAI-compatible)

# 3. Using OpenAI (Original):
#    - Set OPENAI_API_KEY
#    - Leave AGNES_API_KEY and DEEPSEEK_API_KEY empty
#    - Translation will use OpenAI

# 4. TTS Engine:
#    - Edge TTS is used by default (FREE, no API key needed)
#    - Supports 40+ languages and 100+ high-quality neural voices

# 5. Priority order for translation:
#    Agnes AI > DeepSeek > OpenAI > RapidAPI (fallback)
